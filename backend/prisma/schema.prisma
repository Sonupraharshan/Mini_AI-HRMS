generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())
  admins    Admin[]
  mails     Mail[]
}

enum AccountStatus {
  PENDING
  ACTIVE
}

model Admin {
  id           String       @id @default(uuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  email        String       @unique
  passwordHash String
  status       AccountStatus @default(PENDING)
  inviteToken  String?
  rosters      Roster[]
  mailsSent    Mail[]
  createdAt    DateTime     @default(now())
}

model Roster {
  id           String       @id @default(uuid())
  name         String
  adminId      String
  admin        Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  employees    Employee[]
  mails        Mail[]
  createdAt    DateTime     @default(now())
}

model Employee {
  id           String       @id @default(uuid())
  rosterId     String
  roster       Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  name         String
  email        String       @unique
  passwordHash String
  department   String?
  skills       String[]
  walletAddress String?
  status       AccountStatus @default(PENDING)
  inviteToken  String?
  tasks        Task[]
  createdAt    DateTime     @default(now())
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model Task {
  id             String       @id @default(uuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title          String
  description    String
  status         TaskStatus   @default(ASSIGNED)
  complexityScore Int?
  txHash         String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?
}

enum MailType {
  INVITATION
  CUSTOM
}

model Mail {
  id             String       @id @default(uuid())
  subject        String
  body           String
  type           MailType     @default(CUSTOM)
  senderId       String
  sender         Admin        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  orgId          String?
  organization   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rosterId       String?
  roster         Roster?      @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  recipientEmail String
  createdAt      DateTime     @default(now())
}
